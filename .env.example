# Database
DATABASE_URL="postgresql://neonoble:neonoble123@localhost:5432/neonoble_ramp?schema=public"

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET="your-super-secret-jwt-key-here-change-in-production"

# NeoNoble Platform Internal API Client (generated on first run)
NEONOBLE_PLATFORM_API_KEY=""
NEONOBLE_PLATFORM_API_SECRET=""

# Application
NODE_ENV="development"
PORT=3000

# Base URL for production
NEXT_PUBLIC_BASE_URL="https://neonoble.it"

# For local development, use:
# NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Payment Gateway (Stripe)
PAYMENT_MODE="mock"  # 'mock' or 'live'
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Blockchain (BSC)
BSC_RPC_URL="https://bsc-dataseed1.binance.org/"
BSC_PRIVATE_KEY=""  # Platform wallet private key for sending tokens
NENO_CONTRACT_ADDRESS="0x..."  # NENO ERC-20 contract address on BSC
BSC_CONFIRMATIONS=12  # Number of block confirmations required

# Worker Settings
WORKER_ENABLED="true"
WORKER_INTERVAL_MS=5000  # Check pending transactions every 5 seconds

# Rate Limiting
RATE_LIMIT_WINDOW_MS=86400000  # 24 hours
RATE_LIMIT_MAX_REQUESTS=1000  # per window per API client

# Fraud Prevention
FRAUD_CHECK_ENABLED="true"
MAX_TRANSACTION_AMOUNT=100000  # Maximum EUR per transaction
MAX_DAILY_AMOUNT_PER_USER=500000  # Maximum EUR per user per day